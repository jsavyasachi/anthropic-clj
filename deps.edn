{:paths ["src"]

 :deps {org.clojure/clojure {:mvn/version "1.12.5"}
        com.anthropic/anthropic-java {:mvn/version "2.49.1"}
        metosin/jsonista {:mvn/version "1.0.0"}}

 :aliases
 {:test
  {:extra-paths ["test"]
   :extra-deps {lambdaisland/kaocha {:mvn/version "1.91.1392"}
                org.slf4j/slf4j-nop {:mvn/version "2.0.18"}
                com.anthropic/anthropic-java-bedrock {:mvn/version "2.49.1"}
                com.anthropic/anthropic-java-vertex {:mvn/version "2.49.1"}}
   :main-opts ["-m" "kaocha.runner"]}

  :bedrock
  {:extra-deps {com.anthropic/anthropic-java-bedrock {:mvn/version "2.49.1"}}}

  :vertex
  {:extra-deps {com.anthropic/anthropic-java-vertex {:mvn/version "2.49.1"}}}

  :1.10 {:override-deps {org.clojure/clojure {:mvn/version "1.10.3"}}}
  :1.11 {:override-deps {org.clojure/clojure {:mvn/version "1.11.4"}}}
  :1.12 {:override-deps {org.clojure/clojure {:mvn/version "1.12.0"}}}

  :build
  {:deps {io.github.clojure/tools.build {:mvn/version "0.10.14"}
          slipset/deps-deploy {:mvn/version "0.2.5"}}
   :ns-default build}}}
