{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "helpers:pinGitHubActionDigests"],
  "minimumReleaseAge": "10 days",
  "internalChecksFilter": "strict",
  "description": "Track the official Anthropic Java SDK closely - this wrapper's value is staying current with it.",
  "packageRules": [
    {
      "description": "Search Clojars and Maven Central.",
      "matchDatasources": ["clojure"],
      "registryUrls": [
        "https://repo.clojars.org",
        "https://repo.maven.apache.org/maven2"
      ]
    },
    {
      "description": "Surface anthropic-java releases promptly, on their own PR.",
      "matchPackageNames": ["com.anthropic:anthropic-java"],
      "groupName": "anthropic-java",
      "schedule": ["at any time"],
      "prPriority": 10
    }
  ]
}
